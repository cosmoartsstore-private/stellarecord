{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StellaRecord",
  "version": "1.0.0",
  "identifier": "com.cosmoartsstore.stellarecord",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ipc:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {},
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "publisher": "CosmoArtsStore",
    "copyright": "Copyright (c) CosmoArtsStore",
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi",
        "installerHooks": "windows/hooks.nsi",
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["Japanese"],
        "displayLanguageSelector": false
      }
    }
  }
}
