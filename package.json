{
  "name": "stella-record",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint --fix \"src/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "verify": "npm run format:check && npm run stylelint && npm run lint && npm run test && npm run build && npm run fmt:check && npm run clippy && npm run test:rust",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/m-plus-1": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.7"
  }
}
